---
// src/components/Hero.astro
---

<section class="relative min-h-screen w-full overflow-hidden flex items-center justify-center bg-deep-bg">
  
  <div class="absolute inset-0 w-full h-full z-0">
    <video
      class="w-full h-full object-cover opacity-40 grayscale"
      autoplay
      muted
      loop
      playsinline
      poster="/assets/img/Nexonomic_Logo_K_07.jpg"
    >
      <source src="/assets/video/hero.mp4" type="video/mp4" />
    </video>
    
    <div class="absolute inset-0 bg-gradient-to-b from-deep-bg/40 via-deep-bg/85 to-deep-bg z-10"></div>
    <div class="absolute top-1/4 -left-20 w-96 h-96 bg-action/20 rounded-full blur-[120px] z-10"></div>
    <div class="absolute bottom-1/4 -right-20 w-96 h-96 bg-accent/10 rounded-full blur-[120px] z-10"></div>
  </div>

  <div class="relative z-20 text-center px-6 max-w-4xl mx-auto mt-16">
    <p class="font-sans text-accent tracking-[0.3em] uppercase text-xs mb-6 animate-fade-in-up font-bold">
      Economía • Entrevistas • Protagonistas
    </p>
    
    <h1 class="font-serif text-4xl sm:text-5xl md:text-7xl text-white leading-[1.1] mb-8 animate-fade-in-up delay-100">
      La economía, <br/>
      <span class="text-accent italic font-light">explicada por quienes la hacen</span>
    </h1>
    
    <p class="font-sans text-lg md:text-xl text-gray-400 max-w-2xl mx-auto mb-12 leading-relaxed animate-fade-in-up delay-200">
      El espacio que conecta la teoría económica con la experiencia real de quienes toman decisiones.
    </p>
    
    <div class="flex flex-col sm:flex-row gap-5 justify-center animate-fade-in-up delay-300">
      <a href="#about" class="px-10 py-4 bg-action hover:bg-accent text-white font-sans font-bold rounded-full transition-all duration-500 transform hover:-translate-y-1 shadow-lg shadow-action/20">
        Conocer el Proyecto
      </a>
      <a href="#blog" class="px-10 py-4 border border-white/20 hover:bg-white/5 text-white font-sans font-bold rounded-full transition-all duration-500">
        Leer Artículos
      </a>
    </div>
  </div>

  <a href="#about" class="absolute bottom-8 left-0 right-0 mx-auto w-fit z-20 flex flex-col items-center gap-2 text-gray-500 hover:text-accent transition-colors animate-bounce" aria-label="Scroll hacia abajo">
    <span class="font-sans text-xs uppercase tracking-widest">Explorar</span>
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
    </svg>
  </a>
</section>

<style>
  .animate-fade-in-up {
    animation: fadeInUp 1s ease-out forwards;
  }
  .delay-100 { animation-delay: 0.1s; }
  .delay-200 { animation-delay: 0.2s; }
  .delay-300 { animation-delay: 0.3s; }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>