---
// src/components/Footer.astro
const currentYear = new Date().getFullYear();
---

<footer class="bg-black border-t border-white/10 py-16">
  <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-10">
    
    <div class="flex flex-col items-center md:items-start">
      <a href="/" class="mb-4 flex items-center transition-transform hover:scale-105">
        <img src="/assets/img/Nexonomic_Logo_K_07.jpg" class="hidden md:block h-20 w-auto object-contain mix-blend-screen" alt="Nexonomic Logo" />
        <img src="/assets/img/Nexonomic_Logo_K_07.jpg" class="block md:hidden h-14 w-auto object-contain mix-blend-screen" alt="Nexonomic Logo" />
      </a>
      <p class="text-gray-500 text-sm font-sans max-w-xs text-center md:text-left">
        Repensando el futuro económico a través de la reflexión crítica y filosófica.
      </p>
    </div>

    <div class="flex gap-6">
      <a href="#" class="text-gray-400 hover:text-white transition-colors" aria-label="LinkedIn">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" clip-rule="evenodd" /></svg>
      </a>
      <a href="#" class="text-gray-400 hover:text-white transition-colors" aria-label="Twitter / X">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M8.29 20.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0022 5.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.072 4.072 0 012.8 9.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 012 18.407a11.616 11.616 0 006.29 1.84" /></svg>
      </a>
      <a href="#" class="text-gray-400 hover:text-white transition-colors" aria-label="YouTube">
         <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" d="M19.812 5.418c.861.23 1.538.907 1.768 1.768C21.998 8.746 22 12 22 12s0 3.255-.418 4.814a2.504 2.504 0 0 1-1.768 1.768c-1.56.419-7.814.419-7.814.419s-6.255 0-7.814-.419a2.505 2.505 0 0 1-1.768-1.768C2 15.255 2 12 2 12s0-3.255.417-4.814a2.507 2.507 0 0 1 1.768-1.768C5.744 5 11.998 5 11.998 5s6.255 0 7.814.418ZM15.194 12 10 15V9l5.194 3Z" clip-rule="evenodd" /></svg>
      </a>
    </div>

    <div class="text-center md:text-right text-sm text-gray-600 font-sans">
      <p>&copy; {currentYear} Nexonomic. Todos los derechos reservados.</p>
      <div class="mt-1 space-x-2">
        <a href="#" class="hover:text-gray-400 transition-colors">Privacidad</a>
        <span>•</span>
        <a href="#" class="hover:text-gray-400 transition-colors">Términos</a>
      </div>
    </div>

  </div>
</footer>