---
// src/components/Footer.astro
const currentYear = new Date().getFullYear();
---

<footer class="bg-black border-t border-white/10 py-12">
  <div class="max-w-7xl mx-auto px-6">

    <!-- Fila principal -->
    <div class="flex flex-col md:flex-row justify-between items-center md:items-start gap-10 mb-10">

      <!-- Logo + descripción -->
      <div class="flex flex-col items-center md:items-start">
        <a href="/" class="mb-4 flex items-center transition-transform hover:scale-105">
          <img src="/assets/img/Nexonomic_Logo_K_07.jpg" class="h-16 w-auto object-contain mix-blend-screen" alt="Nexonomic Logo" />
        </a>
        <p class="text-gray-500 text-sm font-sans max-w-xs text-center md:text-left leading-relaxed">
          Repensando el futuro económico a través de la reflexión crítica y filosófica.
        </p>
      </div>

      <!-- Redes sociales -->
      <div class="flex flex-col items-center gap-4">
        <p class="text-gray-600 text-xs font-sans uppercase tracking-widest">Seguinos</p>
        <div class="flex gap-5">
          <a href="https://linkedin.com/company/nexonomic" target="_blank" rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="text-gray-500 hover:text-accent transition-colors duration-200">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M4.98 3.5C4.98 4.88 3.87 6 2.5 6S.02 4.88.02 3.5 1.13 1 2.5 1s2.48 1.12 2.48 2.5zM.5 8.5h4V24h-4V8.5zM8.5 8.5h3.84v2.14h.05c.53-1 1.84-2.06 3.79-2.06 4.05 0 4.8 2.66 4.8 6.12V24h-4v-8.55c0-2.04-.04-4.66-2.84-4.66-2.85 0-3.28 2.22-3.28 4.51V24h-4V8.5z"/>
            </svg>
          </a>
          <!-- Instagram — agregar URL cuando esté disponible -->
          <a href="#" aria-label="Instagram" class="text-gray-500 hover:text-accent transition-colors duration-200">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 1.366.062 2.633.334 3.608 1.308.975.975 1.246 2.242 1.308 3.608.058 1.266.07 1.646.07 4.85s-.012 3.584-.07 4.85c-.062 1.366-.334 2.633-1.308 3.608-.975.975-2.242 1.246-3.608 1.308-1.266.058-1.646.07-4.85.07s-3.584-.012-4.85-.07c-1.366-.062-2.633-.334-3.608-1.308-.975-.975-1.246-2.242-1.308-3.608C2.175 15.584 2.163 15.204 2.163 12s.012-3.584.07-4.85c.062-1.366.334-2.633 1.308-3.608C4.516 2.497 5.783 2.225 7.15 2.163 8.416 2.105 8.796 2.163 12 2.163zm0-2.163c-3.259 0-3.667.014-4.947.072-1.52.069-3.01.456-4.123 1.57C1.82 2.756 1.433 4.246 1.364 5.766.307 8.046.293 8.454.293 12s.014 3.954.072 4.947c.069 1.52.456 3.01 1.57 4.123 1.113 1.113 2.603 1.5 4.123 1.57C7.333 23.986 7.741 24 12 24s3.954-.014 4.947-.072c1.52-.069 3.01-.456 4.123-1.57 1.113-1.113 1.5-2.603 1.57-4.123.058-.993.072-1.401.072-4.947s-.014-3.954-.072-4.947c-.069-1.52-.456-3.01-1.57-4.123C19.957.528 18.467.14 16.947.072 15.954.014 15.546 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zm0 10.162a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
            </svg>
          </a>
          <!-- YouTube — agregar URL cuando esté disponible -->
          <a href="#" aria-label="YouTube" class="text-gray-500 hover:text-accent transition-colors duration-200">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Links legales -->
      <div class="flex flex-col items-center md:items-end gap-3 text-xs font-sans text-gray-600">
        <div class="flex gap-4">
          <a href="/terminos" class="hover:text-gray-400 transition-colors">Términos y condiciones</a>
          <a href="/privacidad" class="hover:text-gray-400 transition-colors">Política de privacidad</a>
        </div>
      </div>

    </div>

    <!-- Línea divisoria -->
    <div class="border-t border-white/5 pt-6 flex flex-col sm:flex-row justify-between items-center gap-3 text-xs text-gray-700 font-sans">
      <p>&copy; {currentYear} Nexonomic. Todos los derechos reservados.</p>
      <p>Diseñado y desarrollado por <span class="text-gray-500">Tomas Martinez</span></p>
    </div>

  </div>
</footer>

<style>
  .mix-blend-screen {
    mix-blend-mode: screen;
  }
</style>
