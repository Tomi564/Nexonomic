---
// src/components/Footer.astro
const currentYear = new Date().getFullYear();
---

<footer class="bg-black border-t border-white/10 py-12">
  <div class="max-w-7xl mx-auto px-6">

    <!-- Fila principal -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-10 mb-10">

      <!-- Logo + descripción -->
      <div class="flex flex-col items-center">
        <a href="/" class="mb-4 flex items-center transition-transform hover:scale-105">
          <img src="/assets/img/Nexonomic%20Logo_K-01.jpg" class="h-16 w-auto object-contain mix-blend-screen" alt="Nexonomic Logo" />
        </a>
        <p class="text-gray-500 text-sm font-sans max-w-xs text-center md:text-left leading-relaxed">
          Repensando el futuro económico a través de la reflexión crítica y filosófica.
        </p>
      </div>

      <!-- Redes sociales -->
      <div class="flex flex-col items-center gap-4">
        <p class="text-gray-600 text-xs font-sans uppercase tracking-widest">Seguinos</p>
        <div class="flex gap-6">
          <a href="https://linkedin.com/company/nexonomic" target="_blank" rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="text-gray-500 hover:text-accent transition-colors duration-200">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a href="#" aria-label="Instagram" class="text-gray-500 hover:text-accent transition-colors duration-200">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0C8.74 0 8.333.015 7.053.072 5.775.132 4.905.333 4.14.63c-.789.306-1.459.717-2.126 1.384S.935 3.35.63 4.14C.333 4.905.131 5.775.072 7.053.012 8.333 0 8.74 0 12c0 3.259.012 3.668.072 4.948.06 1.277.261 2.148.558 2.913.306.788.717 1.459 1.384 2.126.667.666 1.336 1.079 2.126 1.384.766.296 1.636.499 2.913.558C8.333 23.988 8.74 24 12 24c3.259 0 3.668-.012 4.948-.072 1.277-.06 2.148-.262 2.913-.558.788-.306 1.459-.718 2.126-1.384.666-.667 1.079-1.335 1.384-2.126.296-.765.499-1.636.558-2.913.06-1.28.072-1.689.072-4.948 0-3.259-.012-3.667-.072-4.947-.06-1.277-.262-2.149-.558-2.913-.306-.789-.718-1.459-1.384-2.126C21.319 1.347 20.651.935 19.86.63c-.765-.297-1.636-.499-2.913-.558C15.667.012 15.259 0 12 0zm0 2.16c3.203 0 3.585.016 4.85.071 1.17.055 1.805.249 2.227.415.562.217.96.477 1.382.896.419.42.679.819.896 1.381.164.422.36 1.057.413 2.227.057 1.266.07 1.646.07 4.85s-.015 3.585-.074 4.85c-.061 1.17-.256 1.805-.421 2.227-.224.562-.479.96-.899 1.382-.419.419-.824.679-1.38.896-.42.164-1.065.36-2.235.413-1.274.057-1.649.07-4.859.07-3.211 0-3.586-.015-4.859-.074-1.171-.061-1.816-.256-2.236-.421-.569-.224-.96-.479-1.379-.899-.421-.419-.69-.824-.9-1.38-.165-.42-.359-1.065-.42-2.235-.045-1.26-.061-1.649-.061-4.844 0-3.196.016-3.586.061-4.861.061-1.17.255-1.814.42-2.234.21-.57.479-.96.9-1.381.419-.419.81-.689 1.379-.898.42-.166 1.051-.361 2.221-.421 1.275-.045 1.65-.06 4.859-.06zm0 3.678a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4zm7.846-10.405a1.441 1.441 0 0 1-2.88 0 1.44 1.44 0 0 1 2.88 0z"/>
            </svg>
          </a>
          <a href="#" aria-label="YouTube" class="text-gray-500 hover:text-accent transition-colors duration-200">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Links legales -->
      <div class="flex flex-col items-center gap-3 text-xs font-sans text-gray-600">
        <div class="flex gap-4">
          <a href="/terminos" class="hover:text-gray-400 transition-colors">Términos y condiciones</a>
          <a href="/privacidad" class="hover:text-gray-400 transition-colors">Política de privacidad</a>
        </div>
      </div>

    </div>

    <!-- Línea divisoria -->
    <div class="border-t border-white/5 pt-6 flex flex-col sm:flex-row justify-between items-center gap-3 text-xs text-gray-700 font-sans">
      <p>&copy; {currentYear} Nexonomic. Todos los derechos reservados.</p>
      <p>Diseñado y desarrollado por <span class="text-gray-500">Tomas Martinez</span></p>
    </div>

  </div>
</footer>

<style>
  .mix-blend-screen {
    mix-blend-mode: screen;
  }
</style>
