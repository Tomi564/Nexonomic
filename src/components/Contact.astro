---
// src/components/Contact.astro
---

<section id="contact" class="py-24 bg-deep-bg relative">
  <div class="absolute inset-0 bg-gradient-to-b from-transparent to-[#000000]/50 pointer-events-none"></div>

  <div class="max-w-4xl mx-auto px-6 relative z-10">
    
    <div class="text-center mb-16">
      <h2 class="font-sans text-accent tracking-widest uppercase text-sm mb-4 font-semibold">
        Conexión
      </h2>
      <h3 class="font-serif text-4xl text-white mb-6">
        Iniciemos una conversación
      </h3>
      <p class="text-gray-400 font-sans max-w-xl mx-auto">
        Ya sea para entrevistas, colaboraciones académicas o consultas sobre el proyecto, su mensaje es bienvenido.
      </p>
    </div>

    <form class="space-y-6 bg-white/5 p-8 md:p-12 rounded-sm border border-white/10 backdrop-blur-sm">
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="flex flex-col gap-2">
          <label for="name" class="text-sm text-gray-400 font-sans">Nombre Completo</label>
          <input 
            type="text" 
            id="name" 
            name="name" 
            placeholder="Juan Pérez"
            class="bg-black/40 border border-white/10 text-white p-3 rounded-sm focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-all"
            required
          />
        </div>

        <div class="flex flex-col gap-2">
          <label for="email" class="text-sm text-gray-400 font-sans">Correo Electrónico</label>
          <input 
            type="email" 
            id="email" 
            name="email" 
            placeholder="juan@ejemplo.com"
            class="bg-black/40 border border-white/10 text-white p-3 rounded-sm focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-all"
            required
          />
        </div>
      </div>

      <div class="flex flex-col gap-2">
        <label for="reason" class="text-sm text-gray-400 font-sans">Motivo del contacto</label>
        <div class="relative">
            <select 
                id="reason" 
                name="reason" 
                class="w-full bg-black/40 border border-white/10 text-white p-3 rounded-sm focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-all appearance-none cursor-pointer"
            >
                <option value="interview">Solicitud de Entrevista</option>
                <option value="collab">Colaboración Académica</option>
                <option value="speaking">Conferencias / Charlas</option>
                <option value="other">Otro asunto</option>
            </select>
            <svg class="absolute right-4 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 pointer-events-none" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
            </svg>
        </div>
      </div>

      <div class="flex flex-col gap-2">
        <label for="message" class="text-sm text-gray-400 font-sans">Mensaje</label>
        <textarea 
          id="message" 
          name="message" 
          rows="5" 
          placeholder="Escriba su mensaje aquí..."
          class="bg-black/40 border border-white/10 text-white p-3 rounded-sm focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-all resize-none"
        ></textarea>
      </div>

      <div class="flex items-center gap-3 pt-2">
        <input 
          type="checkbox" 
          id="newsletter" 
          name="newsletter"
          class="w-5 h-5 border-white/20 rounded bg-black/40 text-accent focus:ring-accent focus:ring-offset-0 cursor-pointer" 
        />
        <label for="newsletter" class="text-sm text-gray-400 cursor-pointer select-none">
          Deseo recibir actualizaciones mensuales sobre nuevos artículos.
        </label>
      </div>

      <div class="pt-4">
        <button 
          type="submit" 
          class="w-full bg-action hover:bg-accent text-white font-bold py-4 rounded-full transition-all duration-300 uppercase tracking-widest text-sm shadow-lg shadow-action/20 hover:shadow-accent/40"
        >
          Enviar Mensaje
        </button>
      </div>

    </form>
  </div>
</section>