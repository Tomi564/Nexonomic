---
// src/components/Contact.astro
---

<section id="contact" class="py-24 bg-deep-bg relative">
  <div class="absolute inset-0 bg-gradient-to-b from-transparent to-[#000000]/50 pointer-events-none"></div>

  <div class="max-w-4xl mx-auto px-6 relative z-10">
    
    <div class="text-center mb-16">
      <h2 class="font-sans text-accent tracking-widest uppercase text-sm mb-4 font-semibold">
        Conexión
      </h2>
      <h3 class="font-serif text-4xl text-white mb-6">
        Iniciemos una conversación
      </h3>
      <p class="text-gray-400 font-sans max-w-xl mx-auto">
        Ya sea para entrevistas, colaboraciones académicas o consultas sobre el proyecto, su mensaje es bienvenido.
      </p>
    </div>

    <form 
      name="contacto" 
      method="POST" 
      data-netlify="true" 
      data-netlify-honeypot="bot-field"
      class="space-y-6 bg-white/5 p-8 md:p-12 rounded-3xl border border-white/10 backdrop-blur-sm"
    >
      <input type="hidden" name="form-name" value="contacto" />
      <p class="hidden">
        <label>No completar: <input name="bot-field" /></label>
      </p>
          
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="flex flex-col gap-2">
        <label for="name" class="text-sm text-gray-400 font-sans">Nombre Completo</label>
        <input type="text" id="name" name="name" placeholder="Juan Pérez"
          class="bg-black/40 border border-white/10 text-white p-3 px-6 rounded-full focus:outline-none focus:border-accent transition-all" required />
      </div>

      <div class="flex flex-col gap-2">
        <label for="email" class="text-sm text-gray-400 font-sans">Correo Electrónico</label>
        <input type="email" id="email" name="email" placeholder="juan@ejemplo.com"
          class="bg-black/40 border border-white/10 text-white p-3 px-6 rounded-full focus:outline-none focus:border-accent transition-all" required />
      </div>
    </div>

    <div class="flex flex-col gap-2">
      <label for="reason" class="text-sm text-gray-400 font-sans">Motivo del contacto</label>
      <div class="relative">
          <select id="reason" name="reason"
            class="w-full bg-black/40 border border-white/10 text-white p-3 px-6 rounded-full focus:outline-none focus:border-accent transition-all appearance-none cursor-pointer pr-12">
              <option value="interview">Solicitud de Entrevista</option>
              <option value="collab">Colaboración Académica</option>
              <option value="speaking">Conferencias / Charlas</option>
              <option value="other">Otro asunto</option>
          </select>
          <svg class="pointer-events-none absolute right-5 top-1/2 -translate-y-1/2 w-4 h-4 text-accent" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
          </svg>
      </div>
    </div>

    <div class="flex flex-col gap-2">
      <label for="message" class="text-sm text-gray-400 font-sans">Mensaje</label>
      <textarea id="message" name="message" rows="5" placeholder="Escriba su mensaje aquí..."
        class="bg-black/40 border border-white/10 text-white p-4 px-6 rounded-3xl focus:outline-none focus:border-accent transition-all resize-none"></textarea>
    </div>

      <label for="newsletter" class="flex items-center gap-3 pt-2 cursor-pointer group">
        <div class="relative flex-shrink-0 w-5 h-5">
          <input
            type="checkbox"
            id="newsletter"
            name="newsletter"
            class="peer sr-only"
          />
          <div class="checkbox-box w-5 h-5 rounded border border-white/20 bg-black/40 peer-checked:bg-accent peer-checked:border-accent transition-all flex items-center justify-center">
            <svg class="checkbox-check w-3 h-3 text-deep-bg transition-transform pointer-events-none" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
          </div>
        </div>
        <span class="text-sm text-gray-400 select-none group-hover:text-gray-300 transition-colors">
          Deseo recibir actualizaciones mensuales sobre nuevos artículos.
        </span>
      </label>

      <div class="pt-4">
        <button
          id="submit-btn"
          type="submit"
          class="w-full bg-action hover:bg-accent text-white font-bold py-4 rounded-full transition-all duration-300 uppercase tracking-widest text-sm shadow-lg shadow-action/20 hover:shadow-accent/40 disabled:opacity-50 disabled:cursor-not-allowed"
        >
          Enviar Mensaje
        </button>
      </div>

      <div id="form-success" class="hidden text-center py-4">
        <p class="text-accent font-sans font-semibold text-lg">Mensaje enviado.</p>
        <p class="text-gray-400 font-sans text-sm mt-1">Gracias por escribir. Te responderé a la brevedad.</p>
      </div>

      <div id="form-error" class="hidden text-center py-4">
        <p class="text-red-400 font-sans font-semibold text-sm">Ocurrió un error al enviar. Por favor intentá de nuevo.</p>
      </div>

    </form>
  </div>
</section>

<style>
  .checkbox-check { transform: scale(0); transition: transform 0.15s ease; }
  .checkbox-checked .checkbox-check { transform: scale(1); }
  .checkbox-checked { background-color: #3cc2a2 !important; border-color: #3cc2a2 !important; }
</style>

<script>
  const newsletterInput = document.getElementById('newsletter') as HTMLInputElement | null;
  const checkboxBox = document.querySelector('.checkbox-box') as HTMLElement | null;
  newsletterInput?.addEventListener('change', () => {
    checkboxBox?.classList.toggle('checkbox-checked', newsletterInput.checked);
  });

  const form = document.querySelector('form[name="contacto"]') as HTMLFormElement | null;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const successMsg = document.getElementById('form-success');
  const errorMsg = document.getElementById('form-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !submitBtn) return;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Enviando...';
    successMsg?.classList.add('hidden');
    errorMsg?.classList.add('hidden');

    try {
      const res = await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(new FormData(form) as unknown as Record<string, string>).toString(),
      });

      if (res.ok) {
        form.reset();
        successMsg?.classList.remove('hidden');
        submitBtn.classList.add('hidden');
      } else {
        throw new Error();
      }
    } catch {
      errorMsg?.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Enviar Mensaje';
    }
  });
</script>