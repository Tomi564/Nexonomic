---
// src/components/Quotes.astro
const quotes = [
  {
    text: "La economía no trata de cosas, sino de relaciones entre personas y, en última instancia, entre clases.",
    author: "Karl Marx",
    role: "Filósofo y Economista"
  },
  {
    text: "El precio es lo que pagas. El valor es lo que obtienes.",
    author: "Warren Buffett",
    role: "Inversor"
  },
  {
    text: "La libertad sin oportunidades es un regalo endiablado y negarse a dar esas oportunidades es criminal.",
    author: "Noam Chomsky",
    role: "Lingüista y Filósofo"
  }
];
---

<section class="py-24 bg-deep-bg relative overflow-hidden">
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-action/10 via-transparent to-transparent opacity-50 pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      
      {quotes.map((quote) => (
        /* Cambiamos el borde lateral recto por una tarjeta con bordes muy redondeados (rounded-3xl) según el estilo de la marca */
        <div class="group relative p-8 bg-white/5 border border-white/10 rounded-3xl hover:border-accent/50 transition-all duration-500 hover:-translate-y-2 shadow-2xl shadow-black/20">
          
          <span class="absolute -top-4 left-6 text-6xl text-accent/20 font-serif group-hover:text-accent/40 transition-colors">“</span>
          
          <blockquote class="relative z-10">
            <p class="font-serif text-xl text-gray-200 italic leading-relaxed mb-6 group-hover:text-white transition-colors">
              "{quote.text}"
            </p>
            <footer class="flex flex-col">
              <cite class="font-sans text-accent font-bold not-italic tracking-wider uppercase text-xs">
                {quote.author}
              </cite>
              <span class="text-gray-500 text-xs mt-1 font-sans">
                {quote.role}
              </span>
            </footer>
          </blockquote>
        </div>
      ))}

    </div>
  </div>
</section>