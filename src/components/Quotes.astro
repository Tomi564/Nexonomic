---
// src/components/Quotes.astro
const quotes = [
  {
    text: "La economía no trata de cosas, sino de relaciones entre personas y, en última instancia, entre clases.",
    author: "Karl Marx",
    role: "Filósofo y Economista"
  },
  {
    text: "El precio es lo que pagas. El valor es lo que obtienes.",
    author: "Warren Buffett",
    role: "Inversor"
  },
  {
    text: "La libertad sin oportunidades es un regalo endiablado y negarse a dar esas oportunidades es criminal.",
    author: "Noam Chomsky",
    role: "Lingüista y Filósofo"
  }
];
---

<section class="py-24 bg-deep-bg relative overflow-hidden">
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-action/10 via-transparent to-transparent opacity-50 pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      
      {quotes.map((quote) => (
        <div class="group relative p-6 border-l-2 border-white/10 hover:border-accent transition-colors duration-500">
          
          <span class="absolute -top-4 left-4 text-6xl text-white/5 font-serif group-hover:text-action/20 transition-colors">“</span>
          
          <blockquote class="relative z-10">
            <p class="font-serif text-xl md:text-2xl text-gray-300 italic leading-relaxed mb-6 group-hover:text-white transition-colors">
              "{quote.text}"
            </p>
            <footer class="flex flex-col">
              <cite class="font-sans font-bold text-accent not-italic text-sm tracking-wide uppercase">
                — {quote.author}
              </cite>
              <span class="text-xs text-muted mt-1 font-sans">
                {quote.role}
              </span>
            </footer>
          </blockquote>
        </div>
      ))}

    </div>
  </div>
</section>