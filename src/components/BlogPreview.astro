---
// src/components/BlogPreview.astro
import { getNoticias } from '../utils/noticias';

const noticias = await getNoticias();

const posts = noticias.map(n => ({
  title: n.data.title,
  category: n.data.category,
  date: n.data.date,
  excerpt: n.data.excerpt,
  image: n.data.image || 'https://images.unsplash.com/photo-1611974765270-ca1258634369?q=80&w=2064&auto=format&fit=crop',
  link: `/blog/${n.slug}`
}));
---

<section id="blog" class="py-24 bg-[#080a0c]">
  <div class="max-w-7xl mx-auto px-6">
    
    <div class="flex justify-between items-end mb-12 border-b border-white/10 pb-6">
      <div>
        <h2 class="font-sans text-accent tracking-widest uppercase text-sm mb-2 font-semibold">
          Pensamiento Reciente
        </h2>
        <h3 class="font-serif text-3xl md:text-4xl text-white">
          Artículos y Ensayos
        </h3>
      </div>
      <a href="/blog" class="hidden md:flex items-center gap-2 text-muted hover:text-white transition-colors text-sm font-sans">
        Ver todo el archivo
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {posts.map((post) => (
        <article class="group">
          <a href={post.link} class="block">
            <div class="relative overflow-hidden aspect-[16/10] mb-4 bg-gray-800 rounded-xl">
              <div class="absolute inset-0 bg-action/20 group-hover:bg-transparent transition-colors z-10"></div>
              <img
                src={post.image}
                alt={post.title}
                class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700 ease-out"
              />
            </div>

            <div class="space-y-3">
              <div class="flex items-center justify-between text-xs font-sans">
                <span class="text-accent uppercase tracking-wider font-bold">
                  {post.category}
                </span>
                <time class="text-gray-500">
                  {post.date}
                </time>
              </div>

              <h4 class="font-serif text-xl text-white group-hover:text-accent transition-colors leading-snug">
                {post.title}
              </h4>

              <p class="font-sans text-sm text-gray-400 line-clamp-3 leading-relaxed">
                {post.excerpt}
              </p>

              <span class="inline-block mt-2 text-sm text-white border-b border-transparent group-hover:border-action transition-all">
                Leer artículo →
              </span>
            </div>
          </a>
        </article>
      ))}
    </div>

  </div>
</section>