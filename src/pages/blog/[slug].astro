---
// src/pages/blog/[slug].astro
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../../keystatic.config';
import { getNoticias, formatDate } from '../../utils/noticias';
import Layout from '../../layouts/Layout.astro';
import { DocumentRenderer } from '@keystatic/core/renderer';

const { slug } = Astro.params;

const noticias = await getNoticias();
const index = noticias.findIndex(n => n.slug === slug);

if (index === -1) {
  return Astro.redirect('/404');
}

const noticia = noticias[index];
const prev = index > 0 ? noticias[index - 1] : null;
const next = index < noticias.length - 1 ? noticias[index + 1] : null;

const reader = createReader(process.cwd(), keystaticConfig);
const post = await reader.collections.noticias.read(slug);

const { title, image, category } = noticia.data;
const date = formatDate(noticia.data.date);
const excerpt = noticia.data.excerpt ?? '';
---

<Layout title={`${title} | Nexonomic`} description={excerpt} ogImage={image}>
  <article class="pt-24 md:pt-32 pb-16 md:pb-24 bg-[#080a0c] min-h-screen">
    <div class="max-w-3xl mx-auto px-6">

      <div class="mb-8">
        <a href="/blog" class="inline-flex items-center gap-2 text-gray-500 hover:text-accent transition-colors font-sans text-sm">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
          </svg>
          Todos los artículos
        </a>
      </div>

      <header class="mb-12">
        <div class="flex items-center gap-4 text-accent uppercase tracking-widest text-xs font-bold mb-4">
          <span>{category}</span>
          <span class="text-gray-600">•</span>
          <time class="text-gray-500">{date}</time>
        </div>
        <h1 class="font-serif text-4xl md:text-5xl text-white leading-tight mb-8">
          {title}
        </h1>

        {image && (
          <div class="aspect-[16/9] overflow-hidden rounded-sm bg-gray-800">
            <img
              src={image}
              alt={title}
              class="w-full h-full object-cover"
            />
          </div>
        )}
      </header>

      <div class="prose prose-invert prose-accent prose-headings:font-serif prose-p:font-sans max-w-none">
        {post
          ? <DocumentRenderer document={await post.content()} />
          : <div set:html={noticia.body.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>').replace(/\n/g, '<br>')} />
        }
      </div>

      <footer class="mt-12 md:mt-16 pt-8 border-t border-white/10">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
          <div>
            {prev && (
              <a href={`/blog/${prev.slug}`} class="group flex flex-col gap-1">
                <span class="text-xs text-gray-500 font-sans uppercase tracking-widest">← Anterior</span>
                <span class="font-serif text-white group-hover:text-accent transition-colors line-clamp-2 sm:line-clamp-1">{prev.data.title}</span>
              </a>
            )}
          </div>
          <a href="/blog" class="text-gray-500 hover:text-accent transition-colors font-sans text-xs uppercase tracking-widest flex-shrink-0 order-first sm:order-none">
            Archivo
          </a>
          <div class="sm:text-right">
            {next && (
              <a href={`/blog/${next.slug}`} class="group flex flex-col gap-1 sm:items-end">
                <span class="text-xs text-gray-500 font-sans uppercase tracking-widest">Siguiente →</span>
                <span class="font-serif text-white group-hover:text-accent transition-colors line-clamp-2 sm:line-clamp-1">{next.data.title}</span>
              </a>
            )}
          </div>
        </div>
      </footer>
    </div>
  </article>
</Layout>

<style is:global>
  .prose h2 { @apply font-serif text-2xl text-white mt-12 mb-4; }
  .prose p { @apply mb-6 text-lg text-gray-400; }
  .prose strong { @apply text-white font-bold; }
  .prose ul { @apply list-disc list-inside mb-6 text-gray-400; }
</style>
