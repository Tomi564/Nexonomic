---
import Layout from '../../layouts/Layout.astro';
import { getNoticias } from '../../utils/noticias';

const noticias = await getNoticias();

const posts = noticias
  .map(n => ({
    title: n.data.title,
    category: n.data.category,
    date: n.data.date,
    excerpt: n.data.excerpt,
    image: n.data.image || 'https://images.unsplash.com/photo-1611974765270-ca1258634369?q=80&w=2064&auto=format&fit=crop',
    link: `/blog/${n.slug}`,
  }))
  .sort((a, b) => (a.date && b.date ? b.date.localeCompare(a.date) : 0));
---

<Layout title="Artículos | Nexonomic">
  <header class="pt-40 pb-16 bg-deep-bg border-b border-white/10">
    <div class="max-w-7xl mx-auto px-6">
      <p class="font-sans text-accent tracking-widest uppercase text-xs mb-4 font-bold">Archivo</p>
      <h1 class="font-serif text-4xl md:text-5xl text-white">Artículos y Ensayos</h1>
    </div>
  </header>

  <main class="bg-deep-bg min-h-screen py-20">
    <div class="max-w-7xl mx-auto px-6">

      {posts.length === 0 ? (
        <p class="text-gray-500 font-sans text-center py-20">No hay artículos publicados aún.</p>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {posts.map((post) => (
            <article class="group">
              <a href={post.link} class="block">
                <div class="relative overflow-hidden aspect-[16/10] mb-4 bg-gray-800 rounded-xl">
                  <div class="absolute inset-0 bg-action/20 group-hover:bg-transparent transition-colors z-10"></div>
                  <img
                    src={post.image}
                    alt={post.title}
                    class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-700 ease-out"
                  />
                </div>
                <div class="space-y-3">
                  <div class="flex items-center justify-between text-xs font-sans">
                    <span class="text-accent uppercase tracking-wider font-bold">{post.category}</span>
                    <time class="text-gray-500">{post.date}</time>
                  </div>
                  <h2 class="font-serif text-xl text-white group-hover:text-accent transition-colors leading-snug">
                    {post.title}
                  </h2>
                  <p class="font-sans text-sm text-gray-400 line-clamp-3 leading-relaxed">
                    {post.excerpt}
                  </p>
                  <span class="inline-block mt-2 text-sm text-white border-b border-transparent group-hover:border-action transition-all">
                    Leer artículo →
                  </span>
                </div>
              </a>
            </article>
          ))}
        </div>
      )}

      <div class="mt-20 pt-8 border-t border-white/10">
        <a href="/" class="text-accent hover:text-white transition-colors font-sans text-sm">
          ← Volver al inicio
        </a>
      </div>

    </div>
  </main>
</Layout>
