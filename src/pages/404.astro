---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Página no encontrada | Nexonomic">
  <div class="min-h-screen bg-deep-bg flex items-center justify-center px-6">
    <div class="text-center max-w-xl">

      <p class="font-sans text-accent tracking-widest uppercase text-xs mb-6 font-bold">Error 404</p>

      <h1 class="font-serif text-6xl md:text-8xl text-white mb-6 leading-none">
        Página no <span class="text-accent italic font-light">encontrada</span>
      </h1>

      <p class="font-sans text-gray-400 text-lg leading-relaxed mb-12">
        La página que buscás no existe o fue movida. Podés volver al inicio o explorar los artículos.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="px-8 py-4 bg-action hover:bg-accent text-white font-sans font-bold rounded-full transition-all duration-300 shadow-lg shadow-action/20">
          Volver al inicio
        </a>
        <a href="/blog" class="px-8 py-4 border border-white/20 hover:bg-white/5 text-white font-sans font-bold rounded-full transition-all duration-300">
          Ver artículos
        </a>
      </div>

    </div>
  </div>
</Layout>
